# ---- Secrets (never commit) ----
firmware/arduino/esp_temp/secrets.h
apple/**/Secrets.xcconfig
# Firebase iOS config (per-project; download from the Firebase console).
# A committed template lives at apple/GoogleService-Info.plist.example.
apple/Sources/App/GoogleService-Info.plist
# Firebase Android config (per-project; download from the Firebase console).
# A committed template lives at android/app/google-services.json.example.
android/app/google-services.json
# Android release signing.
android/keystore.properties

# ---- Firmware build output ----
build/
firmware/**/build/

# ---- Apple / Xcode ----
# XcodeGen generates the .xcodeproj from project.yml -- run `xcodegen generate`.
apple/*.xcodeproj
DerivedData/
*.xcuserstate
xcuserdata/
.swiftpm/
*.xcworkspace/xcuserdata/

# ---- macOS ----
.DS_Store

# ---- Local tooling ----
.claude/settings.local.json
.serena/
