rules_version = '2';

// Multi-tenant, owner-only access. The Cloud Function uses the Admin SDK, which
// bypasses these rules entirely — so alert state can be server-owned while still
// being readable (never writable) by the device owner from the client.
service cloud.firestore {
  match /databases/{database}/documents {

    // A user's own profile + their FCM tokens.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /fcmTokens/{token} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Devices are owned by exactly one user.
    match /devices/{deviceId} {
      allow read:   if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid
                    && request.resource.data.ownerUid == resource.data.ownerUid; // owner is immutable
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;

      // Server-owned alert state. Subcollections do NOT inherit the parent match,
      // so this block is explicit. Owner may read; no client may ever write
      // (the Admin SDK in the Cloud Function bypasses this).
      match /state/{doc} {
        allow read: if request.auth != null
                    && get(/databases/$(database)/documents/devices/$(deviceId)).data.ownerUid == request.auth.uid;
        allow write: if false;
      }
    }

    // Everything else: deny by default.
  }
}
