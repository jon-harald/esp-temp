<?xml version="1.0" encoding="UTF-8"?>
<!--
  TEMPLATE ONLY — do not use as-is.

  Download the real GoogleService-Info.plist from the Firebase console
  (Project settings → Your apps → iOS app with bundle id `no.brathen.esptemp`)
  and save it as:

      apple/Sources/App/GoogleService-Info.plist

  It is git-ignored. XcodeGen's `Sources/App` glob bundles it automatically
  once present, so no project.yml change is needed. See docs/push-setup.md.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>API_KEY</key>
    <string>REPLACE_ME</string>
    <key>GCM_SENDER_ID</key>
    <string>REPLACE_ME</string>
    <key>PLIST_VERSION</key>
    <string>1</string>
    <key>BUNDLE_ID</key>
    <string>no.brathen.esptemp</string>
    <key>PROJECT_ID</key>
    <string>REPLACE_ME</string>
    <key>STORAGE_BUCKET</key>
    <string>REPLACE_ME.appspot.com</string>
    <key>IS_ADS_ENABLED</key>
    <false/>
    <key>IS_ANALYTICS_ENABLED</key>
    <false/>
    <key>IS_APPINVITE_ENABLED</key>
    <true/>
    <key>IS_GCM_ENABLED</key>
    <true/>
    <key>IS_SIGNIN_ENABLED</key>
    <true/>
    <key>GOOGLE_APP_ID</key>
    <string>REPLACE_ME</string>
</dict>
</plist>
